#include <iostream>
#include <vector>
#include <iomanip>

using namespace std;

int main() {
    int n;
    
    // Nhập số lượng phần tử với điều kiện 0 < n < 100
    do {
        cout << "Nhap so luong phan tu n (0 < n < 100): ";
        cin >> n;
        if (n <= 0 || n >= 100) {
            cout << "So n khong hop le. Vui loi nhap lai!" << endl;
        }
    } while (n <= 0 || n >= 100);

    vector<double> x(n);
    double tong = 0;
    int dem = 0;

    // Nhập dãy số và kiểm tra điều kiện ngay khi nhập
    cout << "Nhap cac phan tu cua day:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "x[" << i + 1 << "] = ";
        cin >> x[i];

        // Kiểm tra điều kiện: là số âm và nằm trong khoảng (-1000, -10)
        if (x[i] < -10 && x[i] > -1000) {
            tong += x[i];
            dem++;
        }
    }

    // Xuất kết quả
    cout << "\n------------------------------------" << endl;
    if (dem > 0) {
        double trungBinhCong = tong / dem;
        cout << "Co " << dem << " phan tu thoa man dieu kien (-1000 < x < -10)." << endl;
        cout << "Trung binh cong cac phan tu do la: " << fixed << setprecision(2) << trungBinhCong << endl;
    } else {
        cout << "Khong co phan tu nao trong day thoa man dieu kien." << endl;
    }

    return 0;
}